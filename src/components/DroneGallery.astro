---
const images = [
  { src: '/images/drone-1.png', alt: 'Racing quadcopter bare carbon frame' },
  { src: '/images/drone-2.png', alt: 'Flight controller and ESCs wired up' },
  { src: '/images/drone-3.png', alt: 'Assembled quadcopter with motors' },
  { src: '/images/drone-4.png', alt: 'Finished racing quadcopter with props' },
];
---

<div class="drone-gallery">
  {images.map((img) => (
    <div class="drone-gallery__item">
      <img src={img.src} alt={img.alt} loading="lazy" />
    </div>
  ))}
</div>

<style>
  .drone-gallery {
    display: flex;
    gap: 4px;
    height: 220px;
    border-radius: 10px;
    overflow: hidden;
    margin: var(--space-sm) 0;
  }

  .drone-gallery__item {
    flex: 1;
    overflow: hidden;
    transition: flex 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
    position: relative;
    cursor: pointer;
  }

  .drone-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .drone-gallery:hover .drone-gallery__item {
    flex: 0.5;
  }

  .drone-gallery .drone-gallery__item:hover {
    flex: 3;
  }

  .drone-gallery__item:hover img {
    transform: scale(1.03);
  }

  /* Mobile: horizontal scroll */
  @media (max-width: 720px) {
    .drone-gallery {
      height: 180px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 3px;
    }

    .drone-gallery__item {
      min-width: 70%;
      flex: none;
      scroll-snap-align: center;
    }

    .drone-gallery:hover .drone-gallery__item {
      flex: none;
    }

    .drone-gallery .drone-gallery__item:hover {
      flex: none;
    }
  }
</style>
