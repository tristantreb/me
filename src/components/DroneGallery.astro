---
const base = import.meta.env.BASE_URL;
const images = [
  { src: `${base}/images/drone-1.png`, alt: 'Racing quadcopter bare carbon frame' },
  { src: `${base}/images/drone-2.png`, alt: 'Flight controller and ESCs wired up' },
  { src: `${base}/images/drone-3.png`, alt: 'Assembled quadcopter with motors' },
  { src: `${base}/images/drone-4.png`, alt: 'Finished racing quadcopter with props' },
];
---

<div class="drone-gallery">
  {images.map((img) => (
    <div class="drone-gallery__item">
      <img src={img.src} alt={img.alt} loading="lazy" />
    </div>
  ))}
</div>

<style>
  .drone-gallery {
    display: flex;
    gap: 4px;
    height: 220px;
    max-height: 220px;
    border-radius: 10px;
    overflow: hidden;
    margin: var(--space-sm) 0;
  }

  .drone-gallery__item {
    flex: 1;
    overflow: hidden;
    transition: flex 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
    cursor: pointer;
    height: 220px;
    max-height: 220px;
  }

  .drone-gallery__item img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 220px;
    object-fit: cover;
    object-position: center;
  }

  .drone-gallery:hover .drone-gallery__item {
    flex: 0.5;
  }

  .drone-gallery .drone-gallery__item:hover {
    flex: 3;
  }

  @media (max-width: 720px) {
    .drone-gallery {
      height: 180px;
      max-height: 180px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 3px;
    }

    .drone-gallery__item {
      min-width: 70%;
      flex: none;
      scroll-snap-align: center;
      height: 180px;
      max-height: 180px;
    }

    .drone-gallery:hover .drone-gallery__item {
      flex: none;
    }

    .drone-gallery .drone-gallery__item:hover {
      flex: none;
    }
  }
</style>
